          "runs": [
            {
              "text": "BERT / NLI scoring on Colab CPU => slow & unstable",
              "color": "#D64545",
              "bold": true
            }
          ]
        },
        {
          "runs": [
            {
              "text": "Generating N = 20 samples x 238 passages => expensive",
              "color": "#D64545",
              "bold": true
            }
          ]
        },
        {
          "runs": [
            {
              "text": "What we did: reduced N from 20 to 10",
              "color": "#1F9D55",
              "bold": true
            }
          ]
        },
        {
          "runs": [
            {
              "text": "Sample-size curve plateaus early, so fewer samples keep the signal"
            }
          ],
          "level": 1
        }
      ],
      "note": [
        {
          "text": "Reduce sample size to balance cost and feasibility."
        }
